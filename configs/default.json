{
    "preprocessing": {
        "final_width": [256],
        "img_path": [
            "images/artwork/seurat.jpg"
        ]
    },
    "primitive": {
        "primitive_file": "arial.ttf",
        "text": ["s","e", "u", "r", "a", "t"],
        "primitive_hollow": false,
        "output_width": 128
    },
    "initialization": {
        "initializer": "structure_aware",
        "N": [2000],
        "radii_min": 2,
        "debug_mode": true,
        "detail_first": false
    },
    "optimization": {
        "use_fp16": true,
        "num_iterations": 100,
        "learning_rate": {
            "default": 0.1
        },
        "do_decay": true,
        "do_gaussian_blur": true,
        "loss_config": {
            "type": "combined",
            "components": [
                {"name": "mse", "weight": 1.0},
                {"name": "perceptual", "weight": 0.2}
            ]
        }
    },
    "postprocessing": {
        "output_folder": "outputs/",
        "compute_psnr": true,
        "export_psd": true
    }
} 