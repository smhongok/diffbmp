{
    "preprocessing": {
        "final_width": [
            256
        ],
        "img_path": [
            "images/gif/pororo_monkey_crop_first2.gif"
        ]
    },
    "primitive": {
        "primitive_file": "arial.ttf",
        "text": "B",
        "primitive_hollow": false,
        "output_width": 128
    },
    "initialization": {
        "initializer": "structure_aware",
        "N": [
            2000
        ],
        "radii_min": 2,
        "debug_mode": true
    },
    "optimization": {
        "use_fp16": false,
        "renderer_type": "tile",
        "num_iterations": 100,
        "learning_rate": {
            "default": 0.1
        },
        "do_decay": true,
        "do_gaussian_blur": true,
        "first_frame": {
            "num_iterations": 100,
            "learning_rate": {
                "default": 0.1
            }
        }
    },
    "sequential": {
        "enabled": true,
        "input_type": "gif",
        "max_frames": null,
        "optimization": {
            "num_iterations": 100,
            "learning_rate": {
                "default": 0.1
            },
            "decay_rate": 0.98,
            "warmup_steps": 10
        },
        "adaptive_control": {
            "enabled": true,
            "tile_rows": 4,
            "tile_cols": 4,
            "scale_threshold": 12.0,
            "opacity_threshold": 0.7,
            "opacity_reduction_factor": 0.4,
            "max_primitives_per_tile": 4,
            "apply_epochs": [20, 40, 60, 80],
            "gradient_ranking": {
                "enabled": false,
                "pixels_per_tile": 64
            }
        },
        "export": {
            "export_frames": true,
            "export_gif": true,
            "export_mp4": true,
            "frame_duration": 100
        }
    },
    "postprocessing": {
        "output_folder": "./outputs/reduce_code/pororo_monkey/",
        "hires_export": false,
        "hires_scale_factor": 4.0,
        "compute_psnr": true,
        "export_psd": true
    },
    "seed": 42
}
