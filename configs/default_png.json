{
    "preprocessing": {
        "final_width": [
            256
        ],
        "img_path": [
            "images/person/안중근.jpg"
        ]
    },
    "primitive": {
        "primitive_file": "hand.jpeg",
        "convert_to_svg": false,
        "primitive_hollow": false,
        "output_width": 128
    },
    "initialization": {
        "initializer": "structure_aware",
        "N": [
            2000
        ],
        "radii_min": 2,
        "debug_mode": true
    },
    "optimization": {
        "use_fp16": false,
        "renderer_type": "tile",
        "num_iterations": 100,
        "learning_rate": {
            "default": 0.1
        },
        "do_decay": true,
        "do_gaussian_blur": true
    },
    "postprocessing": {
        "output_folder": "outputs/",
        "compute_psnr": true,
        "export_psd": true
    }
}