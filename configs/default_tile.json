{
    "preprocessing": {
        "final_width": [
            256
        ],
        "img_path": [
            "images/artwork/seurat.jpg"
        ]
    },
    "primitive": {
        "primitive_file": "arial.ttf",
        "text": [
            "S",
            "e",
            "u",
            "r",
            "a",
            "t"
        ],
        "primitive_hollow": false,
        "output_width": 128
    },
    "initialization": {
        "initializer": "structure_aware",
        "N": [
            2000
        ],
        "radii_min": 2,
        "debug_mode": true
    },
    "optimization": {
        "use_fp16": false,
        "renderer_type": "tile",
        "tile_size": 32,
        "num_iterations": 100,
        "learning_rate": {
            "default": 0.1
        },
        "do_decay": true,
        "do_gaussian_blur": true,
        "densifying": {
            "do_densify": false,
            "densify_warmup": 10,
            "densify_duration": 24,
            "densify_loss_coeff": 1.0,
            "densifying_period": 4,
            "densified_N": 3000,
            "grad_threshold": 0.01
        }
    },
    "postprocessing": {
        "output_folder": "./outputs/tile_1",
        "save_final_image": true,
        "save_video": false,
        "video_fps": 30,
        "save_gif": false,
        "gif_fps": 10,
        "save_pdf": false,
        "pdf_width": 8.5,
        "pdf_height": 11,
        "pdf_dpi": 300,
        "save_svg": false,
        "save_params": true,
        "save_intermediate": false,
        "intermediate_interval": 10,
        "export_psd": true
    },
    "logging": {
        "log_interval": 10,
        "save_logs": true,
        "log_level": "INFO"
    },
    "seed": 42
}