{
    "preprocessing": {
        "final_width": [
            512
        ],
        "img_path": [
            "images/spatial_constraint/15.jpg"
        ],
        "mask_path": "images/spatial_constraint/masks/00015_hair.png",
        "exist_bg" : false,
        "debug_save_intermediates" : true,
        "prevent_overshooting" : {
            "color_for_background": "random",
            "anti_aliasing_sigma": 3,
            "binary_threshold" : 80
        }
    },
    "primitive": {
        "primitive_file": "mike_white_bg.png",
        "convert_to_svg": false,
        "svg_hollow": false,
        "output_width": 128
    },
    "initialization": {
        "initializer": "structure_aware",
        "N": [
            500
        ],
        "radii_min": 2,
        "radii_max": 64,
        "debug_mode": true
    },
    "optimization": {
        "use_fp16": false,
        "num_iterations": 300,
        "learning_rate": {
            "default": 0.1,
            "gain_v":5.0
        },
        "loss_config": {
            "type": "combined",
            "components": [
                {"name": "mse", "weight": 1.0},
                {"name": "alpha", "weight": 0.3}
            ]
        },
        "pruning":{
            "do_pruning" : true,
            "prune_iterations" : 50,
            "no_prune_last_iterations" : 0,
            "no_prune_warmup_iterations" : 199,
            "prune_threshold" : 0.3
        },
        "do_decay": true,
        "do_gaussian_blur": true,
        "c_blend": 0.7,
        "alpha_upper_bound" : 0.7
    },
    "postprocessing": {
        "output_folder": "outputs/",
        "compute_psnr": true,
        "export_psd": false
    }
} 