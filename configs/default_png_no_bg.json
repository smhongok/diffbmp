{
    "preprocessing": {
        "final_width": [
            256
        ],
        "img_path": [
            "images/person/pororo_no_background.png"
        ],
        "exist_bg": false
    },
    "primitive": {
        "primitive_file": "hand.jpeg",
        "convert_to_svg": false,
        "primitive_hollow": false,
        "output_width": 128
    },
    "initialization": {
        "initializer": "structure_aware",
        "N": [
            2000
        ],
        "radii_min": 2,
        "debug_mode": true,
        "distance_factor": 0.7
    },
    "optimization": {
        "use_fp16": false,
        "renderer_type": "tile",
        "num_iterations": 300,
        "learning_rate": {
            "default": 0.1,
            "gain_v": 3
        },
        "loss_weights": {
            "color_loss_weight": 1.0,
            "alpha_loss_weight": 2.0
        },
        "pruning": {
            "do_pruning": true,
            "prune_iterations": 10,
            "no_prune_last_iterations": 50,
            "no_prune_warmup_iterations": 200,
            "prune_threshold": 0.3
        },
        "do_decay": true,
        "do_gaussian_blur": true
    },
    "postprocessing": {
        "output_folder": "outputs/",
        "compute_psnr": true,
        "export_psd": true
    }
}