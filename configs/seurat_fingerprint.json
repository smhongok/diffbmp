{
  "preprocessing": {
    "final_width": [512],
    "img_path": [
      "images/artwork/seurat_painting_small.jpg"
    ]
  },
  "primitive": {
    "primitive_file": "fingerprint.jpg",
    "convert_to_svg": false,
    "primitive_hollow": false,
    "output_width": 128,
    "radial_transparency": true
  },
  "initialization": {
    "initializer": "structure_aware",
    "N": [400],
    "v_init_bias": -4.0,
    "radii_min": 8,
    "radii_max": 10,
    "debug_mode": false
  },
  "optimization": {
    "use_fp16": false,
    "num_iterations": 500,
    "learning_rate": {
      "default": 0.1
    },
    "c_blend": 0.0,
    "alpha_upper_bound": 1.0,
    "loss_config": {
      "type": "combined",
      "components": [
        {"name": "mse", "weight": 1.0},
        {"name": "overlap_penalty", "weight": 0.00001, "penalty_weight": 0.01},
        {"name": "size_regularization", "weight": 0.0001, "target_size": 9.0}
      ]
    },
    "do_decay": true,
    "do_gaussian_blur": true
  },
  "postprocessing": {
    "output_folder": "outputs/",
    "compute_psnr": true,
    "export_psd": true,
    "psd_scale_factor": 2.0
  }
}
