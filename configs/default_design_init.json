{
    "preprocessing": {
        "final_width": [512],
        "img_path": [
            "images/person/vangogh1.jpg"
        ]
    },
    "primitive": {
        "primitive_file": ["fingerprint.jpg"],
        "convert_to_svg": false,
        "primitive_hollow": false,
        "output_width": 128
    },
    "initialization": {
        "initializer": "designated",
        "N": [9],
        "x": [0.25, 0.5, 0.75, 0.25, 0.5, 0.75, 0.25, 0.5, 0.75],
        "y": [0.25, 0.25, 0.25, 0.5, 0.5, 0.5, 0.75, 0.75, 0.75],
        "r": [40, 40, 40, 40, 40, 40, 40, 40, 40],
        "theta": [0, 0, 0, 0, 0, 0, 0, 0, 0],
        "v": [5, 5, 5, 5, 5, 5, 5, 5, 5],
        "debug_mode": true
    },
    "optimization": {
        "use_fp16": true,
        "num_iterations": 100,
        "learning_rate": {
            "default": 0.1
        },
        "do_decay": true,
        "do_gaussian_blur": true,
        "c_blend": 0.0,
        "loss_config": {
            "type": "combined",
            "components": [
                {"name": "mse", "weight": 1.0},
                {"name": "perceptual", "weight": 0.2}
            ]
        }
    },
    "postprocessing": {
        "output_folder": "outputs/",
        "compute_psnr": true,
        "export_psd": true
    }
} 