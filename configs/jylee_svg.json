{
    "preprocessing": {
        "final_width": 128,
        "trim": false,
        "FM_halftone": false,
        "transform": "none",
        "img_path": "images/jylee.png",
        "bg_threshold": 250,
        "do_equalize": false,
        "do_local_contrast": false,
        "local_contrast":{
            "radius": 2.0,
            "amount": 3.0
        },
        "do_tone_curve": false,
        "tone_params": {
            "in_low": 50,
            "in_high": 200,
            "out_low": 30,
            "out_high": 230
        },
        "vertical_paddings": [0, 0]
    },
    "svg": {
        "svg_file": "images/apple.svg",
        "svg_hollow": false
    },
    "initialization": {
        "template_matching": false,
        "N": 10000,
        "min_distance": 5,
        "peak_threshold": 0.5,
        "radii_min": 2,
        "arc_thickness": 1,
        "v_init_mean": -5.0
    },
    "optimization": {
        "num_iterations": 300,
        "learning_rate": 0.1,
        "alpha_upper_bound": 0.3
    },
    "postprocessing": {
        "output_path": "outputs/jylee_svg_N=10000.pdf",
        "linewidth": 3.0
    }
}