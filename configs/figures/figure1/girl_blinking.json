{
    "preprocessing": {
        "final_width": [
            512
        ],
        "img_path": [
            "images/spatial_constraint/sequential"
        ],
        "exist_bg" : false,
        "resampling": "NEAREST"
    },
    "primitive": {
        "primitive_file": ["flowers/Lady_Jane.png", "flowers/rose_of_sharon_1.png"],
        "convert_to_svg": false,
        "svg_hollow": false,
        "output_width": 128
    },
    "initialization": {
        "initializer": "structure_aware",
        "N": [
            1000
        ],
        "radii_min": 2,
        "radii_max": 20,
        "debug_mode": true
    },
    "optimization": {
        "use_fp16": false,
        "num_iterations": 300,
        "learning_rate": {
            "default": 0.1,
            "gain_v":5.0
        },
        "do_decay": true,
        "do_gaussian_blur": true,
        "loss_config": {
            "type": "combined",
            "components": [
                {"name": "mse", "weight": 1.0},
                {"name": "alpha", "weight": 0.3}
            ]
        },
        "pruning":{
            "do_pruning" : true,
            "prune_iterations" : 50,
            "no_prune_last_iterations" : 0,
            "no_prune_warmup_iterations" : 199,
            "prune_threshold" : 0.3
        },
        "c_blend": 0.3,
        "alpha_upper_bound" : 0.7
    },
    "sequential": {
        "enabled": true,
        "input_type": "sequence",
        "max_frames": 2,
        "seperate_init": false,
        "optimization": {
            "num_iterations": 100,
            "learning_rate": {
                "default": 0.1
            },
            "decay_rate": 0.98,
            "warmup_steps": 10,
            "loss_config": {
                "type": "combined",
                "components": [
                    {"name": "mse", "weight": 1.0},
                    {"name": "perceptual", "weight": 0.2}
                ]
            }
        },
        "adaptive_control": {
            "enabled": true,
            "tile_rows": 4,
            "tile_cols": 4,
            "scale_threshold": 0.1,
            "opacity_threshold": 0.7,
            "opacity_reduction_factor": 0.3,
            "max_primitives_per_tile": 4,
            "min_criteria_count": 3,
            "front_primitives_percentile": 0.7,
            "apply_epochs": [20, 45, 70]
        },
        "selective_parameter_optimization":{
            "enabled": true,
            "freeze_distance_threshold": 0.0,
            "diff_magnitude_threshold": 0.05,
            "tight_freezemask": true
        },
        "export": {
            "export_frames": true,
            "export_gif": true,
            "export_mp4": false,
            "frame_duration": 100
        }
    },
    "postprocessing": {
        "output_folder": "./outputs/girl_blink/",
        "compute_psnr": false,
        "export_psd": true
    },
    "seed": 42
}
