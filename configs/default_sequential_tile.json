            "max_primitives_per_tile": 6,
            "apply_every_n_iterations": 10,
            "color_nerf": {
                "enabled": false,
                "mode": "pixel"
            }
        },
        "combined_loss": {
            "enabled": false,
            "grayscale_weight": 0.3,
            "color_weight": 0.7,
            "use_gradient_loss": false,
            "gradient_weight": 0.1,
            "use_cosine_similarity": false,
            "use_canny_loss": true,
            "canny_weight": 0.2
        },
        "export": {
            "export_frames": true,
            "export_gif": true,
            "export_mp4": true,
            "frame_duration": 100
        }
    },
    "postprocessing": {
        "output_folder": "./outputs/tile_1",
        "save_final_image": true,
        "save_video": false,
        "video_fps": 30,
        "save_gif": false,
        "gif_fps": 10,
        "save_pdf": false,
        "pdf_width": 8.5,
        "pdf_height": 11,
        "pdf_dpi": 300,
        "save_svg": false,
        "save_params": true,
        "save_intermediate": false,
