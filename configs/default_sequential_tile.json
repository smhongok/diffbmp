{
    "preprocessing": {
        "final_width": [
            256
        ],
        "img_path": [
            "images/gif/pororo_monkey_crop_first2.gif"
        ]
    },
    "primitive": {
        "primitive_file": "arial.ttf",
        "text": [
            "P",
            "o",
            "r",
            "o",
            "r",
            "o"
        ],
        "primitive_hollow": false,
        "output_width": 128
    },
    "initialization": {
        "initializer": "structure_aware",
        "N": [
            2000
        ],
        "radii_min": 2,
        "debug_mode": true
    },
    "optimization": {
        "use_fp16": false,
        "renderer_type": "tile",
        "tile_size": 32,
        "num_iterations": 100,
        "learning_rate": {
            "default": 0.1
        },
        "do_decay": true,
        "do_gaussian_blur": true,
        "densifying": {
            "do_densify": false,
            "densify_warmup": 10,
            "densify_duration": 24,
            "densify_loss_coeff": 1.0,
            "densifying_period": 4,
            "densified_N": 3000,
            "grad_threshold": 0.01
        }
    },
    "sequential": {
        "enabled": true,
        "input_type": "gif",
        "max_frames": null,
        "tile_size": 32,
        "optimization": {
            "num_iterations": 100,
            "learning_rate": {
                "default": 0.1
            },
            "decay_rate": 0.98,
            "warmup_steps": 10
        },
        "adaptive_control": {
            "enabled": true,
            "tile_rows": 8,
            "tile_cols": 8,
            "scale_threshold": 8.0,
            "opacity_threshold": 0.5,
