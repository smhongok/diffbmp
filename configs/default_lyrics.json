{
    "preprocessing": {
        "final_width": [256],
        "img_path": [
            "images/person/pororo.jpg"
        ]
    },
    "primitive": {
        "primitive_file": "MaruBuri-Regular.otf",
        "text_file": "BTY.txt",
        "remove_punctuation": false,
        "primitive_hollow": false,
        "output_width": 128
    },
    "initialization": {
        "initializer": "structure_aware",
        "N": "unspecified",
        "radii_min": 1,
        "radii_max": 16,
        "debug_mode": true,
        "detail_first": false
    },
    "optimization": {
        "use_fp16": true,
        "num_iterations": 100,
        "learning_rate": {
            "default": 0.1
        },
        "do_decay": true,
        "do_gaussian_blur": true
    },
    "postprocessing": {
        "output_folder": "outputs/",
        "compute_psnr": true,
        "export_psd": false
    }
} 