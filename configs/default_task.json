{
    "preprocessing": {
        "final_width": 256,
        "img_path": "images/person/junghun.png"
    },
    "primitive": {
        "primitive_file": "arial.ttf",
        "text": [
            "D",
            "B",
            "H"
        ],
        "primitive_hollow": false,
        "output_width": 128
    },
    "initialization": {
        "initializer": "structure_aware",
        "N": 3000,
        "radii_min": 2,
        "debug_mode": true
    },
    "optimization": {
        "use_fp16": false,
        "renderer_type": "tile",
        "num_iterations": 100,
        "learning_rate": {
            "default": 0.1
        },
        "do_decay": true,
        "do_gaussian_blur": true
    },
    "postprocessing": {
        "compute_psnr": true,
        "export_psd": true
    }
}