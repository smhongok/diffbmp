{
    "preprocessing": {
        "final_width": [256,512],
        "trim": false,
        "FM_halftone": false,
        "transform": "none",
        "img_path": [
            "images/CelebA/182340.png",
            "images/CelebA/182341.png",
            "images/CelebA/182342.png",
            "images/BSDS500/101085.jpg",
            "images/BSDS500/101087.jpg",
            "images/BSDS500/102061.jpg",
            "images/HighFreq/0831.png",
            "images/MoviePosters/1.6_56415.jpg",
            "images/MoviePosters/1.6_245943.jpg",
            "images/MoviePosters/1.9_270846.jpg"
        ],
        "bg_threshold": 250,
        "do_equalize": false,
        "do_local_contrast": false,
        "local_contrast":{
            "radius": 2.0,
            "amount": 3.0
        },
        "do_tone_curve": false,
        "tone_params": {
            "in_low": 50,
            "in_high": 200,
            "out_low": 30,
            "out_high": 230
        },
        "vertical_paddings": [0, 0]
    },
    "svg": {
        "svg_file": "arial.ttf",
        "text": "S",
        "svg_hollow": false,
        "output_width": 128
    },
    "initialization": {
        "initializer": "random",
        "N": [1000, 3000, 5000],
        "alpha": 0.3,
        "min_distance": 5,
        "peak_threshold": 0.5,
        "radii_min": 10,
        "v_init_bias":  -1.5,
        "v_init_slope": 3.0,
        "keypoint_extracting": false,
        "debug_mode": true,
        "prune_tau": 0.01,
        "pruning_enabled": true,
        "level": 2,
        "multi_level": true,
        "hollow": false
    },
    "optimization": {
        "use_fp16": true,
        "renderer_type": "lpips",
        "num_iterations": 100,
        "batch_optimization": false,
        "batch_size": 256,
        "learning_rate": {
            "default": 0.5, 
            "gain_x": 5.0,
            "gain_y": 5.0,
            "gain_r": 20.0,
            "gain_v": 1.0,
            "gain_theta": 5.0,
            "gain_c": 1.0
        },
        "do_decay": true,
        "decay_rate": 0.99,
        "alpha_upper_bound": 1.0,
        "do_gaussian_blur": true,
        "blur_sigma_start": 2.0,
        "blur_sigma_end": 1.0,
        "sparsifying": { 
            "do_sparsify": false,
            "sparsify_warmup": 100,
            "sparsify_duration": 100,
            "sparsify_loss_coeff": 0.5,
            "sparsifying_period": 20,
            "sparsified_N": 1500
        }
    },
    "postprocessing": {
        "output_folder": "outputs/",
        "linewidth": 3.0,
        "compute_psnr": true
    }
} 