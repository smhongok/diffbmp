{
    "preprocessing": {
        "final_width": [
            256
        ],
        "img_path": [
            "images/gif/pororo_monkey_crop_first2.gif"
        ]
    },
    "primitive": {
        "primitive_file": "arial.ttf",
        "text": "B",
        "primitive_hollow": false,
        "output_width": 128
    },
    "initialization": {
        "initializer": "structure_aware",
        "N": [
            2000
        ],
        "radii_min": 2,
        "debug_mode": true
    },
    "optimization": {
        "use_fp16": false,
        "num_iterations": 100,
        "learning_rate": {
            "default": 0.1
        },
        "do_decay": true,
        "do_gaussian_blur": true,
        "loss_config": {
            "type": "combined",
            "components": [
                {"name": "mse", "weight": 1.0},
                {"name": "perceptual", "weight": 0.2}
            ]
        }
    },
    "sequential": {
        "enabled": true,
        "input_type": "gif",
        "max_frames": null,
        "seperate_init": false,
        "optimization": {
            "num_iterations": 100,
            "learning_rate": {
                "default": 0.1
            },
            "decay_rate": 0.98,
            "warmup_steps": 10,
            "loss_config": {
                "type": "combined",
                "components": [
                    {"name": "mse", "weight": 1.0},
                    {"name": "perceptual", "weight": 0.2}
                ]
            }
        },
        "adaptive_control": {
            "enabled": true,
            "tile_rows": 4,
            "tile_cols": 4,
            "scale_threshold": 0.225,
            "opacity_threshold": 0.7,
            "opacity_reduction_factor": 0.1,
            "max_primitives_per_tile": 4,
            "min_criteria_count": 3,
            "front_primitives_percentile": 0.7,
            "apply_epochs": [20, 45, 70],
            "gradient_ranking": {
                "enabled": true,
                "process_all_pixels": true,
                "pixels_per_tile": 64
            }
        },
        "selective_parameter_optimization":{
            "enabled": true,
            "freeze_distance_threshold": 0.05,
            "diff_magnitude_threshold": 0.1,
            "gradual_freeze": {
                "enabled": false,
                "strength": 0.5
            }
        },
        "export": {
            "export_frames": true,
            "export_gif": true,
            "export_mp4": false,
            "frame_duration": 100
        }
    },
    "postprocessing": {
        "output_folder": "./outputs/freeze_test/proro/11",
        "hires_export": false,
        "hires_scale_factor": 4.0,
        "compute_psnr": true,
        "export_psd": false
    },
    "seed": 42
}
