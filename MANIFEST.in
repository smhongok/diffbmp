# Include important files in the package distribution
include README.md
include LICENSE
include requirements.txt

# Include CUDA source files
recursive-include cuda_tile_rasterizer *.cu *.h *.cpp *.py

# Include configuration files
recursive-include configs *.json *.yaml *.yml

# Include assets
recursive-include assets *.svg *.png *.jpg *.ttf *.otf

# Exclude unnecessary files
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .DS_Store
global-exclude *.so
global-exclude *.egg-info
