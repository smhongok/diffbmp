# Include important files in the package distribution
include README.md
include LICENSE
include requirements.txt

# Include CUDA source files (for reference, not compilation)
recursive-include cuda_tile_rasterizer *.cu *.h *.cpp
include cuda_tile_rasterizer/*.py
include cuda_tile_rasterizer/cuda_tile_rasterizer/__init__.py
include cuda_tile_rasterizer/cuda_tile_rasterizer_fp16/__init__.py

# Include pre-built CUDA extensions (.so files) - only from final locations
include cuda_tile_rasterizer/cuda_tile_rasterizer/*.so
include cuda_tile_rasterizer/cuda_tile_rasterizer_fp16/*.so
include cuda_tile_rasterizer/*.so

# Exclude unnecessary files
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .DS_Store
global-exclude *.egg-info
prune cuda_tile_rasterizer/build
prune configs
prune assets
prune images
prune output
prune visualization_output
global-exclude *.json
global-exclude *.yaml
global-exclude *.yml
global-exclude *.sh
global-exclude *.md
